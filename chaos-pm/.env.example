# ── Supabase (required) ─────────────────────────────────
# from Supabase project settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ── Server-only (DO NOT expose to client) ───────────────
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
LIVEBLOCKS_SECRET_KEY=sk_prod_...

# ── Optional: legacy public Liveblocks key for local dev ─
# Only used when Supabase is NOT configured. Production must use the auth endpoint.
# VITE_LIVEBLOCKS_PUBLIC_KEY=pk_dev_...

# ── Mixpanel (optional, client-side analytics) ──────────
# VITE_MIXPANEL_TOKEN=...

# ── Vercel Cron (server-only, for /api/cron/backup) ────
# Generate any random string (>= 32 chars). Vercel injects it as
# Authorization: Bearer <secret> when calling cron-scheduled endpoints.
# CRON_SECRET=

# ── Sentry (optional, error monitoring) ────────────────
# Project DSN — without this, Sentry stays disabled (no overhead)
# VITE_SENTRY_DSN=https://...@o....ingest.sentry.io/...
# Optional release tag (commit SHA) so error reports group by deploy
# VITE_GIT_SHA=auto-set-by-vercel
